@page
@model KBVIEW.Pages.UserProfileModel
@{
    ViewData["Title"] = "User Profile";
}

<div class="profile-container">
    <h1>User Profile</h1>

    <div class="profile-card">
        <div class="profile-avatar">
            <div class="avatar-circle">@Model.Username?.Substring(0, 1).ToUpper()</div>
        </div>

        <div class="profile-info">
            <h2>@Model.Username</h2>
            <p>@Model.Email</p>
        </div>

        <form method="post" asp-page-handler="Logout">
            <button type="submit" class="btn-logout">Logout</button>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .profile-container {
            color: white;
            max-width: 600px;
            margin: 50px auto;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        .profile-card {
            background: rgba(255, 255, 255, 0.1);
            padding: 40px;
            border-radius: 12px;
            text-align: center;
        }

        .avatar-circle {
            width: 100px;
            height: 100px;
            background: #6b5b95;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            font-weight: bold;
            margin: 0 auto 20px;
        }

        .profile-info h2 {
            margin: 0 0 10px 0;
        }

        .profile-info p {
            color: #ccc;
            margin: 0 0 30px 0;
        }

        .btn-logout {
            padding: 12px 30px;
            background: #c62828;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
        }

            .btn-logout:hover {
                background: #d32f2f;
            }
    </style>
}